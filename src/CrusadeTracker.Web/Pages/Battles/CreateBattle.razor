@page "/battles/create"
@attribute [Authorize]
@inject BattleService BattleService
@inject ForceService ForceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

@using CrusadeTracker.Application.Forces.DTOs
@using CrusadeTracker.Application.Units.DTOs

<PageTitle>Record Battle - Crusade Tracker</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Class="pa-6 mt-4" Elevation="3" Style="background: #252540;">
        <MudText Typo="Typo.h4" Class="mb-4" Style="color: #d4af37;">Record New Battle</MudText>

        @if (_isLoadingForces)
        {
            <MudProgressCircular Color="Color.Warning" Indeterminate="true" />
        }
        else if (_forces is null || _forces.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                You need to create a force before recording battles. <MudLink Href="/forces/create" Color="Color.Warning">Create a force</MudLink> first.
            </MudAlert>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="@_formIsValid">
                <MudDatePicker @bind-Date="_battleDate"
                               Label="Battle Date"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="Date is required"
                               Class="mb-3" />

                <MudTextField @bind-Value="_mission"
                              Label="Mission"
                              Placeholder="e.g., Supply Drop, Take and Hold"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Mission is required"
                              Class="mb-3" />

                <MudNumericField @bind-Value="_pointsLimit"
                                 Label="Battle Points Limit"
                                 Variant="Variant.Outlined"
                                 Min="1"
                                 Required="true"
                                 RequiredError="Points limit is required"
                                 Class="mb-3" />

                <MudSelect T="Guid"
                           Value="_selectedForceId"
                           Label="Your Force"
                           Variant="Variant.Outlined"
                           Required="true"
                           RequiredError="Select a force"
                           Class="mb-3"
                           ValueChanged="@((Guid val) => OnForceSelected(val))">
                    @foreach (var force in _forces)
                    {
                        <MudSelectItem Value="@force.Id">@force.Name (@force.Faction) - @force.TotalPoints pts</MudSelectItem>
                    }
                </MudSelect>

                @if (_isLoadingUnits)
                {
                    <MudProgressCircular Color="Color.Warning" Size="Size.Small" Indeterminate="true" Class="mb-3" />
                }
                else if (_forceDetail is not null && _forceDetail.Units.Count > 0)
                {
                    <MudText Typo="Typo.subtitle1" Class="mb-2" Style="color: #d4af37;">
                        Select Units (@_selectedTotalPoints / @_pointsLimit pts)
                    </MudText>

                    @if (_selectedTotalPoints > _pointsLimit)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">
                            Selected units exceed the battle points limit by @(_selectedTotalPoints - _pointsLimit) points.
                        </MudAlert>
                    }

                    <MudPaper Class="pa-3 mb-4" Style="background: #1e1e35;">
                        @foreach (var unit in _forceDetail.Units)
                        {
                            <MudCheckBox T="bool"
                                         Value="@_selectedUnitIds.Contains(unit.Id)"
                                         ValueChanged="@((bool isChecked) => ToggleUnit(unit.Id, unit.Points, isChecked))"
                                         Color="Color.Warning"
                                         Dense="true"
                                         Class="mb-1">
                                <MudText>@unit.Name — @unit.Points pts (@unit.DataSheet)</MudText>
                            </MudCheckBox>
                        }
                    </MudPaper>
                }
                else if (_forceDetail is not null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
                        This force has no units. Add units to the force before recording a battle.
                    </MudAlert>
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               Size="Size.Large"
                               Disabled="@(!CanSubmit)"
                               OnClick="HandleCreate">
                        @if (_isCreating)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                            <span>Creating...</span>
                        }
                        else
                        {
                            <span>Record Battle</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               Size="Size.Large"
                               Href="/battles">
                        Cancel
                    </MudButton>
                </MudStack>
            </MudForm>
        }
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = default!;
    private List<ForceResponse>? _forces;
    private ForceDetailResponse? _forceDetail;
    private bool _isLoadingForces = true;
    private bool _isLoadingUnits;
    private bool _formIsValid;
    private bool _isCreating;

    private DateTime? _battleDate = DateTime.Today;
    private string _mission = string.Empty;
    private int _pointsLimit = 1000;
    private Guid _selectedForceId;
    private HashSet<Guid> _selectedUnitIds = new();
    private int _selectedTotalPoints;

    private bool CanSubmit => _formIsValid
        && !_isCreating
        && _selectedUnitIds.Count > 0
        && _selectedTotalPoints <= _pointsLimit;

    protected override async Task OnInitializedAsync()
    {
        await LoadForces();
    }

    private async Task LoadForces()
    {
        _isLoadingForces = true;
        try
        {
            _forces = await ForceService.GetForcesAsync();
            if (_forces?.Count > 0)
            {
                _selectedForceId = _forces[0].Id;
                await LoadForceUnits(_selectedForceId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading forces: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingForces = false;
        }
    }

    private async Task OnForceSelected(Guid forceId)
    {
        _selectedForceId = forceId;
        _selectedUnitIds.Clear();
        _selectedTotalPoints = 0;
        await LoadForceUnits(forceId);
    }

    private async Task LoadForceUnits(Guid forceId)
    {
        _isLoadingUnits = true;
        try
        {
            _forceDetail = await ForceService.GetForceAsync(forceId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading units: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingUnits = false;
        }
    }

    private void ToggleUnit(Guid unitId, int points, bool isChecked)
    {
        if (isChecked)
        {
            _selectedUnitIds.Add(unitId);
            _selectedTotalPoints += points;
        }
        else
        {
            _selectedUnitIds.Remove(unitId);
            _selectedTotalPoints -= points;
        }
    }

    private async Task HandleCreate()
    {
        await _form.ValidateAsync();
        if (!CanSubmit || _battleDate is null) return;

        _isCreating = true;

        try
        {
            var selectedForce = _forces?.FirstOrDefault(f => f.Id == _selectedForceId);
            var utcDate = DateTime.SpecifyKind(_battleDate.Value.Date, DateTimeKind.Utc);
            var battleDate = new DateTimeOffset(utcDate, TimeSpan.Zero);

            // Create the battle with points limit
            var battle = await BattleService.CreateBattleAsync(battleDate, _mission, _pointsLimit);

            if (battle is not null)
            {
                // Add the user's force as a participant with selected units
                var updatedBattle = await BattleService.AddParticipantAsync(
                    battle.Id,
                    _selectedForceId,
                    _selectedUnitIds.ToList(),
                    selectedForce?.Name);

                if (updatedBattle is not null)
                {
                    Snackbar.Add("Battle recorded successfully!", Severity.Success);
                    Navigation.NavigateTo($"/battles/{battle.Id}");
                }
                else
                {
                    Snackbar.Add("Battle created but failed to add your force.", Severity.Warning);
                    Navigation.NavigateTo($"/battles/{battle.Id}");
                }
            }
            else
            {
                Snackbar.Add("Failed to create battle. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCreating = false;
        }
    }
}
